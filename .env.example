# ============================================================
# AgroBot V7 — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no repositório.
# ============================================================

# Google Gemini API — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Telegram Bot — obtido via @BotFather no Telegram
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Google Cloud Document AI
# Project ID do seu projeto no GCP (ex: meu-projeto-123)
GCP_PROJECT_ID=YOUR_GCP_PROJECT_ID_HERE
# Região do processador Document AI (geralmente "us" ou "eu")
DOCUMENTAI_LOCATION=us
# ID do processador Document AI (tipo OCR) criado no seu projeto GCP
DOCUMENTAI_PROCESSOR_ID=YOUR_DOCUMENTAI_PROCESSOR_ID_HERE

# Backend de visão computacional — somente "documentai" é suportado
VISION_BACKEND=documentai

# (Opcional) Identificador da amostra preferencial quando o laudo contém
# múltiplas linhas de amostras. Deixe vazio para usar a primeira linha.
# Exemplo: PREFER_AMOSTRA=AM 01
PREFER_AMOSTRA=

# ============================================================
# Variáveis legadas (WhatsApp / Meta — server.py, não utilizado)
# ============================================================
VERIFY_TOKEN=YOUR_WHATSAPP_VERIFY_TOKEN_HERE
WHATSAPP_TOKEN=YOUR_WHATSAPP_ACCESS_TOKEN_HERE
PHONE_NUMBER_ID=YOUR_WHATSAPP_PHONE_NUMBER_ID_HERE
